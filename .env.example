# Required before public deployment
ADMIN_USERNAME=admin
ADMIN_PASSWORD=replace-with-a-strong-password
JWT_SECRET_KEY=replace-with-at-least-32-random-characters
XIANYU_REPLY_API_SECRET=
GEETEST_CAPTCHA_ID=
GEETEST_PRIVATE_KEY=

# Server
PORT=8091
API_HOST=0.0.0.0
TZ=Asia/Shanghai
DB_PATH=data/xianyu_data.db
LOG_LEVEL=INFO
SQL_LOG_ENABLED=true
SQL_LOG_LEVEL=INFO

# Optional global AI configuration; it can also be configured in the UI
AI_API_URL=https://api.deepseek.com
AI_MODEL=deepseek-chat
AI_API_KEY=

# Optional SMTP configuration; connection tests do not send mail
SMTP_SERVER=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
SMTP_FROM=
SMTP_USE_TLS=true
SMTP_USE_SSL=false
